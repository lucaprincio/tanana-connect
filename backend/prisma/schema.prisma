generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  CITOYEN
  ADMIN
}

enum Status {
  EN_ATTENTE
  EN_COURS
  RESOLU
}

model User {
  id        Int      @id @default(autoincrement())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(CITOYEN)
  createdAt DateTime @default(now())
  reports   Report[]
}

model Report {
  id          Int      @id @default(autoincrement())
  title       String
  description String
  imageUrl    String?
  latitude    Float
  longitude   Float
  status      Status   @default(EN_ATTENTE)
  userId      Int
  user        User     @relation(fields: [userId], references: [id])
  createdAt   DateTime @default(now())
}